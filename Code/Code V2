#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BNO055.h>
#include <utility/imumaths.h>

Adafruit_BNO055 bno = Adafruit_BNO055(55, 0x28);

// ── Motor pins ──
#define ENA 5
#define IN1 6
#define IN2 7
#define ENB 8
#define IN3 9
#define IN4 10

// ── Encoder pins ──
#define ENC_LEFT_A  2
#define ENC_LEFT_B  4
#define ENC_RIGHT_A 3
#define ENC_RIGHT_B 11

// ── Encoder state ──
volatile long leftTicks  = 0;
volatile long rightTicks = 0;

void leftISR()  { leftTicks++;  }
void rightISR() { rightTicks++; }

// ── Physical constants ──
const float TICKS_PER_REV = 1383.0;
const float WHEEL_RADIUS  = 0.0619;  // meters
// Forward = counterclockwise = ticks increment, but we define
// forward velocity as positive, so no flip needed since both
// wheels increment going forward
const float ENCODER_DIR   = 1.0;

// ── Inner loop gains (angle control) ──
// Start here, tune Kp first then Kd
float Kp_inner = 15.0;
float Kd_inner = 0.8;

// ── Outer loop gains (velocity control) ──
// Keep at 0 until inner loop is stable
float Kp_outer = 0.0;
float Ki_outer = 0.0;

// ── State ──
float targetPitch    = 0.0;
float outerIntegral  = 0.0;
float lastLeftTicks  = 0;
float lastRightTicks = 0;
unsigned long lastTime = 0;

// ── Safety & hardware ──
#define FALL_ANGLE 30.0
#define PWM_MIN    30
#define PWM_MAX    255

// ────────────────────────────────────────────────
// SENSORS
// ────────────────────────────────────────────────

float getPitch() {
  // Forward tilt = more negative pitch
  imu::Quaternion q = bno.getQuat();
  q.normalize();
  return atan2(
    2.0f * (q.w() * q.x() + q.y() * q.z()),
    1.0f - 2.0f * (q.x() * q.x() + q.y() * q.y())
  ) * 180.0f / M_PI;
}

float getGyroRate() {
  // Forward tilt = Gx goes negative
  imu::Vector<3> gyro = bno.getVector(Adafruit_BNO055::VECTOR_GYROSCOPE);
  return gyro.x();
}

float getVelocity(float dt) {
  float dLeft  = leftTicks  - lastLeftTicks;
  float dRight = rightTicks - lastRightTicks;
  lastLeftTicks  = leftTicks;
  lastRightTicks = rightTicks;

  float avgTicks = (dLeft + dRight) / 2.0f;
  float velocity = ENCODER_DIR * WHEEL_RADIUS *
                   (avgTicks / TICKS_PER_REV) *
                   2.0f * M_PI / dt;
  return velocity;
}

// ────────────────────────────────────────────────
// INNER LOOP — angle control
// error = pitch - targetPitch
// Forward tilt → error negative → need positive output (drive forward)
// So output = -(Kp * error + Kd * gyroRate)
// When leaning forward: error < 0, gyroRate < 0
// -(negative + negative) = positive output ✓
// ────────────────────────────────────────────────

float innerLoop(float pitch, float gyroRate, float target) {
  float error  = pitch - target;
  float output = -(Kp_inner * error + Kd_inner * gyroRate);
  return output;
}

// ────────────────────────────────────────────────
// OUTER LOOP — velocity control
// Outputs a small lean angle correction in degrees
// If moving forward (positive velocity) → lean back slightly
// → positive pitch correction added to target
// ────────────────────────────────────────────────

float outerLoop(float velocity, float dt) {
  outerIntegral += velocity * dt;
  outerIntegral  = constrain(outerIntegral, -5.0f, 5.0f);

  float correction = Kp_outer * velocity + Ki_outer * outerIntegral;
  return constrain(correction, -3.0f, 3.0f);
}

// ────────────────────────────────────────────────
// MOTORS
// motorA = left, motorB = right (mirrored)
// Positive speed = forward for both
// ────────────────────────────────────────────────

void motorA(int speed) {
  speed = constrain(speed, -PWM_MAX, PWM_MAX);
  if (abs(speed) < PWM_MIN) {
    digitalWrite(IN1, LOW); digitalWrite(IN2, LOW);
    analogWrite(ENA, 0); return;
  }
  if (speed > 0) { digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW); }
  else           { digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH); speed = -speed; }
  analogWrite(ENA, speed);
}

void motorB(int speed) {
  // Mirrored — IN3/IN4 flipped
  speed = constrain(speed, -PWM_MAX, PWM_MAX);
  if (abs(speed) < PWM_MIN) {
    digitalWrite(IN3, LOW); digitalWrite(IN4, LOW);
    analogWrite(ENB, 0); return;
  }
  if (speed > 0) { digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH); }
  else           { digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW);  speed = -speed; }
  analogWrite(ENB, speed);
}

void stopMotors() { motorA(0); motorB(0); }

// ────────────────────────────────────────────────
// SETUP
// ────────────────────────────────────────────────

void setup() {
  Serial.begin(115200);

  pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT); pinMode(ENB, OUTPUT);
  stopMotors();

  pinMode(ENC_LEFT_A,  INPUT_PULLUP);
  pinMode(ENC_LEFT_B,  INPUT_PULLUP);
  pinMode(ENC_RIGHT_A, INPUT_PULLUP);
  pinMode(ENC_RIGHT_B, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(ENC_LEFT_A),  leftISR,  CHANGE);
  attachInterrupt(digitalPinToInterrupt(ENC_RIGHT_A), rightISR, CHANGE);

  if (!bno.begin()) {
    Serial.println("BNO055 not found — check wiring.");
    while (1);
  }
  bno.setExtCrystalUse(true);

  // Let IMU fully stabilize
  Serial.println("Hold robot UPRIGHT and still — calibrating in 3 seconds...");
  delay(3000);

  // Average 200 readings for setpoint
  float sum = 0;
  for (int i = 0; i < 200; i++) {
    sum += getPitch();
    delay(5);
  }
  targetPitch = sum / 200.0f;
  lastLeftTicks  = leftTicks;
  lastRightTicks = rightTicks;

  Serial.print("Balance point: "); Serial.println(targetPitch);
  Serial.println("Balancing — release!");
  lastTime = millis();
}

// ────────────────────────────────────────────────
// MAIN LOOP
// ────────────────────────────────────────────────

void loop() {
  unsigned long now = millis();
  float dt = (now - lastTime) / 1000.0f;
  if (dt < 0.005f) return;  // cap at 200Hz
  lastTime = now;

  // Read all sensors
  float pitch    = getPitch();
  float gyroRate = getGyroRate();
  float velocity = getVelocity(dt);

  // Safety cutoff — if fallen, stop and wait
  if (abs(pitch - targetPitch) > FALL_ANGLE) {
    stopMotors();
    outerIntegral = 0;
    Serial.println("FALLEN — stopped");
    delay(500);
    return;
  }

  // Outer loop → small pitch target correction based on velocity
  float pitchCorrection = outerLoop(velocity, dt);

  // Inner loop → motor output
  float output = innerLoop(pitch, gyroRate, targetPitch + pitchCorrection);
  output = constrain(output, -PWM_MAX, PWM_MAX);

  motorA((int)output);
  motorB((int)output);

  // Serial plotter output
  Serial.print("Pitch:");   Serial.print(pitch);
  Serial.print(" Target:"); Serial.print(targetPitch + pitchCorrection);
  Serial.print(" Err:");    Serial.print(pitch - (targetPitch + pitchCorrection));
  Serial.print(" Rate:");   Serial.print(gyroRate);
  Serial.print(" Vel:");    Serial.print(velocity);
  Serial.print(" Out:");    Serial.println((int)output);
}
